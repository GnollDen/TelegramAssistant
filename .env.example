# TelegramAssistant .env template (full docker-compose coverage)
# Copy to .env and set secrets/IDs.

# Image override (optional)
IMAGE_TAG=
MCP_IMAGE_TAG=

# Optional build proxy settings (used by `docker compose build`).
# Keep NuGet hosts in NO_PROXY for faster restore with VPN/proxy setups.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,api.nuget.org,nuget.org,globalcdn.nuget.org

# PostgreSQL
POSTGRES_PASSWORD=your_strong_password_here

# Redis pending reclaim observability
REDIS_ENABLE_PENDING_RECLAIM=true
REDIS_PENDING_RECLAIM_INTERVAL_SECONDS=30
REDIS_PENDING_MIN_IDLE_SECONDS=60
REDIS_PENDING_RECLAIM_BATCH_SIZE=100
REDIS_PENDING_METRICS_LOG_INTERVAL_SECONDS=60
REDIS_PENDING_METRICS_SAMPLE_SIZE=100

# MCP server (SSE)
MCP_TRANSPORT=sse
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=3800
MCP_SSE_AUTH_TOKEN=change_me_mcp_token
MCP_SSE_ALLOW_CONTAINER_BIND=true

# Telegram
TG_API_ID=
TG_API_HASH=
TG_PHONE=+7XXXXXXXXXX
TG_BOT_TOKEN=
TG_OWNER_ID=
BOTCHAT_OWNER_ID=
TG_MONITORED_CHATS=885574984,5276431471,3719942125

# LLM keys (OpenRouter)
GEMINI_API_KEY=
CLAUDE_API_KEY=

# Grafana / budgets
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LLM_BUDGET_HOURLY_USD=0.50
LLM_BUDGET_DAILY_USD=10.00

# Media
MEDIA_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct
MEDIA_ARCHIVE_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct
MEDIA_AUDIO_MODEL=openai/gpt-audio-mini
MEDIA_BURST_GUARD=true
MEDIA_BURST_THRESHOLD=10
MEDIA_BURST_KEEP_COUNT=2
MEDIA_BURST_WINDOW_SECONDS=120

# Voice paralinguistics
VOICE_PARALINGUISTICS_ENABLED=true
VOICE_PARALINGUISTICS_TRANSCRIPTION_ENABLED=true
VOICE_PARALINGUISTICS_DELETE_SOURCE_AUDIO_AFTER_PROCESSING=true
VOICE_PARALINGUISTICS_POLL_INTERVAL_SECONDS=10
VOICE_PARALINGUISTICS_BATCH_SIZE=30
VOICE_PARALINGUISTICS_MAX_PARALLEL=2
VOICE_PARALINGUISTICS_MODEL=openai/gpt-audio-mini
VOICE_PARALINGUISTICS_MAX_TOKENS=300
VOICE_PARALINGUISTICS_RETRY_COUNT=2
VOICE_PARALINGUISTICS_RETRY_BASE_DELAY_SECONDS=2
VOICE_PARALINGUISTICS_TRANSIENT_BACKOFF_BASE_SECONDS=60
VOICE_PARALINGUISTICS_TRANSIENT_BACKOFF_MAX_SECONDS=900

# Archive import
ARCHIVE_IMPORT_ENABLED=false
ARCHIVE_MEDIA_PROCESSING_ENABLED=true
ARCHIVE_IMPORT_REQUIRE_CONFIRMATION=true
ARCHIVE_IMPORT_CONFIRM_PROCESSING=false
ARCHIVE_IMPORT_SOURCE_PATH=/data/archive/result.json
ARCHIVE_IMPORT_MEDIA_BASE_PATH=/data/archive
ARCHIVE_IMPORT_BATCH_SIZE=500
ARCHIVE_IMPORT_MAX_PARALLEL_MEDIA=10
ARCHIVE_IMPORT_RPM=300
ARCHIVE_IMPORT_POLL_INTERVAL_SECONDS=5
ARCHIVE_IMPORT_MAX_MEDIA_SIZE_MB=50

# History backfill
BACKFILL_ENABLED=false
BACKFILL_SINCE_DATE=2026-03-07
BACKFILL_CHAT_IDS=

# Analysis / Stage5
ANALYSIS_ENABLED=false
ANALYSIS_CHEAP_MODEL=deepseek/deepseek-v3.2
ANALYSIS_CHEAP_MODEL_AB_ENABLED=false
ANALYSIS_CHEAP_BASELINE_MODEL=openai/gpt-4o-mini
ANALYSIS_CHEAP_CANDIDATE_MODEL=deepseek/deepseek-v3.2
ANALYSIS_CHEAP_AB_CANDIDATE_PERCENT=50
ANALYSIS_EXPENSIVE_MODEL=anthropic/claude-3.5-sonnet
ANALYSIS_EXPENSIVE_FALLBACK_MODEL=openai/gpt-4o
ANALYSIS_BATCH_SIZE=100
ANALYSIS_CHEAP_BATCH_WORKERS=1
ANALYSIS_CHEAP_LLM_PARALLELISM=4
ANALYSIS_CHEAP_MAX_TOKENS=2000
ANALYSIS_CHEAP_PROVIDER_ORDER=
ANALYSIS_CHEAP_PROVIDER_ALLOW_FALLBACKS=true
ANALYSIS_POLL_INTERVAL_SECONDS=5
ANALYSIS_MAX_EXPENSIVE_PER_BATCH=0
ANALYSIS_EXPENSIVE_DAILY_BUDGET_USD=0.15
ANALYSIS_HTTP_TIMEOUT_SECONDS=120
ANALYSIS_EXPENSIVE_COOLDOWN_MINUTES=10
ANALYSIS_EXPENSIVE_CONTEXT_MAX_FACTS=60
ANALYSIS_EXPENSIVE_CONTEXT_MAX_CHARS=12000
ANALYSIS_CHEAP_CONFIDENCE_THRESHOLD=0.8
ANALYSIS_MIN_FACT_CONFIDENCE=0.55
ANALYSIS_MIN_SENSITIVE_FACT_CONFIDENCE=0.75
ANALYSIS_MIN_RELATIONSHIP_CONFIDENCE=0.6
ANALYSIS_TEMPORAL_FACT_SUPERSEDE_TTL_HOURS=12
ANALYSIS_LOCAL_BURST_CONTEXT_MESSAGES=6
ANALYSIS_LOCAL_BURST_CONTEXT_WINDOW_MINUTES=120
ANALYSIS_SESSION_CONTEXT_LOOKBACK_MESSAGES=80
ANALYSIS_SESSION_CONTEXT_GAP_MINUTES=180
ANALYSIS_SESSION_START_CONTEXT_MESSAGES=4
ANALYSIS_HISTORICAL_SUMMARY_CONTEXT_ITEMS=6
ANALYSIS_SUMMARY_ENABLED=true
ANALYSIS_SUMMARY_MODEL=openai/gpt-4o-mini
ANALYSIS_SUMMARY_POLL_INTERVAL_SECONDS=30
ANALYSIS_SUMMARY_BATCH_SIZE=100
ANALYSIS_SUMMARY_DAY_MAX_MESSAGES=500
ANALYSIS_SUMMARY_SESSION_MAX_MESSAGES=120
ANALYSIS_SUMMARY_SESSION_GAP_MINUTES=180
ANALYSIS_SUMMARY_MIN_MESSAGES=4
ANALYSIS_EPISODIC_SESSION_GAP_MINUTES=120
ANALYSIS_SUMMARY_HISTORICAL_HINTS_ENABLED=true
ANALYSIS_SUMMARY_HISTORICAL_HINTS_TOP_K=3
ANALYSIS_SUMMARY_HISTORICAL_HINTS_CANDIDATE_POOL=12
ANALYSIS_SUMMARY_HISTORICAL_HINTS_TIMEOUT_MS=2000
ANALYSIS_SUMMARY_HISTORICAL_HINTS_QUERY_MAX_CHARS=2000
ANALYSIS_SUMMARY_HISTORICAL_HINTS_MAX_CHARS_PER_ITEM=320
ANALYSIS_SUMMARY_HISTORICAL_HINTS_MIN_SIMILARITY=0.72
ANALYSIS_EDIT_DIFF_ENABLED=true
ANALYSIS_EDIT_DIFF_BATCH_SIZE=20
ANALYSIS_EDIT_DIFF_POLL_INTERVAL_SECONDS=5
ANALYSIS_EDIT_DIFF_MAX_TOKENS=320
ANALYSIS_TEST_MODE_MAX_SESSIONS_PER_CHAT=100
ANALYSIS_EPISODIC_SHORT_SESSION_MERGE_THRESHOLD=10
ANALYSIS_EPISODIC_SHORT_SESSION_MAX_BRIDGE_GAP_MINUTES=1440
ANALYSIS_EPISODIC_MAX_SESSIONS_PER_CHAT=0
ANALYSIS_ENABLE_TEST_MODE_SESSION_CAP=false
ANALYSIS_SESSION_CHUNK_SIZE=40
ANALYSIS_SESSION_ANALYSIS_BATCH_SIZE=20
ANALYSIS_SESSION_ANALYSIS_MIN_IDLE_MINUTES=15
ANALYSIS_SESSION_CHUNK_TARGET_CHARS=6000
ANALYSIS_SESSION_CHUNK_MAX_CHARS=9000
ANALYSIS_SESSION_CHUNK_MIN_MESSAGES=12
ANALYSIS_SESSION_CHUNK_HARD_MAX_MESSAGES=80
ANALYSIS_SESSION_CHUNK_PAUSE_GAP_MINUTES=25
ANALYSIS_CHEAP_CHUNK_TARGET_CHARS=12000
ANALYSIS_CHEAP_CHUNK_MAX_CHARS=15000
ANALYSIS_CHEAP_CHUNK_MIN_MESSAGES=6
ANALYSIS_CHEAP_CHUNK_PAUSE_GAP_MINUTES=20
ANALYSIS_SUMMARY_MAX_TOKENS=800
AGGREGATION_MIN_IDLE_AGE_HOURS=6
AGGREGATION_ARCHIVE_THRESHOLD_HOURS=24

# Merge
MERGE_ENABLED=true
MERGE_POLL_INTERVAL_SECONDS=60
MERGE_MAX_CANDIDATES_PER_RUN=500
MERGE_SEMANTIC_GATE_ENABLED=true
MERGE_SEMANTIC_REJECT_SIMILARITY_THRESHOLD=0.55
MERGE_SEMANTIC_AUTO_MERGE_SIMILARITY_THRESHOLD=0.92
MERGE_SEMANTIC_AUTO_MERGE_MIN_EVIDENCE=2

# Monitoring / maintenance
MONITORING_ENABLED=true
MONITORING_POLL_INTERVAL_SECONDS=60
MAINTENANCE_ENABLED=true
MAINTENANCE_FACT_DECAY_ENABLED=true
MAINTENANCE_POLL_INTERVAL_MINUTES=60
MAINTENANCE_EXTRACTION_ERRORS_RETENTION_DAYS=14
MAINTENANCE_STAGE5_METRICS_RETENTION_DAYS=30
MAINTENANCE_MERGE_DECISIONS_RETENTION_DAYS=90

# Neo4j sync
NEO4J_ENABLED=false
NEO4J_BASE_URL=http://127.0.0.1:7474
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_POLL_INTERVAL_SECONDS=30
NEO4J_BATCH_SIZE=200

# Embedding pipeline
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_POLL_INTERVAL_SECONDS=30
EMBEDDING_BATCH_SIZE=100
