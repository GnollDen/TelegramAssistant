# TelegramAssistant .env template (full docker-compose coverage)
# Copy to .env and set secrets/IDs.

# Image override (optional)
IMAGE_TAG=

# PostgreSQL
POSTGRES_PASSWORD=your_strong_password_here

# Telegram
TG_API_ID=
TG_API_HASH=
TG_PHONE=+7XXXXXXXXXX
TG_BOT_TOKEN=
TG_OWNER_ID=
TG_MONITORED_CHATS=885574984,5276431471,3719942125

# LLM keys (OpenRouter)
GEMINI_API_KEY=
CLAUDE_API_KEY=

# Grafana / budgets
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LLM_BUDGET_HOURLY_USD=0.50
LLM_BUDGET_DAILY_USD=10.00

# Media
MEDIA_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct
MEDIA_ARCHIVE_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct
MEDIA_AUDIO_MODEL=openai/gpt-audio-mini
MEDIA_BURST_GUARD=true
MEDIA_BURST_THRESHOLD=10
MEDIA_BURST_KEEP_COUNT=2
MEDIA_BURST_WINDOW_SECONDS=120

# Voice paralinguistics
VOICE_PARALINGUISTICS_ENABLED=true
VOICE_PARALINGUISTICS_POLL_INTERVAL_SECONDS=10
VOICE_PARALINGUISTICS_BATCH_SIZE=30
VOICE_PARALINGUISTICS_MAX_PARALLEL=2
VOICE_PARALINGUISTICS_MODEL=openai/gpt-audio-mini
VOICE_PARALINGUISTICS_MAX_TOKENS=300
VOICE_PARALINGUISTICS_RETRY_COUNT=2
VOICE_PARALINGUISTICS_RETRY_BASE_DELAY_SECONDS=2

# Archive import
ARCHIVE_IMPORT_ENABLED=false
ARCHIVE_MEDIA_PROCESSING_ENABLED=true
ARCHIVE_IMPORT_REQUIRE_CONFIRMATION=true
ARCHIVE_IMPORT_CONFIRM_PROCESSING=false
ARCHIVE_IMPORT_SOURCE_PATH=/data/archive/result.json
ARCHIVE_IMPORT_MEDIA_BASE_PATH=/data/archive
ARCHIVE_IMPORT_BATCH_SIZE=500
ARCHIVE_IMPORT_MAX_PARALLEL_MEDIA=10
ARCHIVE_IMPORT_RPM=300
ARCHIVE_IMPORT_POLL_INTERVAL_SECONDS=5
ARCHIVE_IMPORT_MAX_MEDIA_SIZE_MB=50

# Analysis / Stage5
ANALYSIS_ENABLED=false
ANALYSIS_CHEAP_MODEL=deepseek/deepseek-chat
ANALYSIS_CHEAP_MODEL_AB_ENABLED=false
ANALYSIS_CHEAP_BASELINE_MODEL=openai/gpt-4o-mini
ANALYSIS_CHEAP_CANDIDATE_MODEL=deepseek/deepseek-chat
ANALYSIS_CHEAP_AB_CANDIDATE_PERCENT=50
ANALYSIS_EXPENSIVE_MODEL=anthropic/claude-3.5-sonnet
ANALYSIS_EXPENSIVE_FALLBACK_MODEL=openai/gpt-4o
ANALYSIS_BATCH_SIZE=8
ANALYSIS_POLL_INTERVAL_SECONDS=5
ANALYSIS_MAX_EXPENSIVE_PER_BATCH=10
ANALYSIS_HTTP_TIMEOUT_SECONDS=120
ANALYSIS_EXPENSIVE_COOLDOWN_MINUTES=10
ANALYSIS_EXPENSIVE_CONTEXT_MAX_FACTS=60
ANALYSIS_EXPENSIVE_CONTEXT_MAX_CHARS=12000
ANALYSIS_CHEAP_CONFIDENCE_THRESHOLD=0.8
ANALYSIS_MIN_FACT_CONFIDENCE=0.55
ANALYSIS_MIN_SENSITIVE_FACT_CONFIDENCE=0.75
ANALYSIS_MIN_RELATIONSHIP_CONFIDENCE=0.6

# Merge
MERGE_ENABLED=true
MERGE_POLL_INTERVAL_SECONDS=60
MERGE_MAX_CANDIDATES_PER_RUN=500
MERGE_SEMANTIC_GATE_ENABLED=true
MERGE_SEMANTIC_REJECT_SIMILARITY_THRESHOLD=0.55
MERGE_SEMANTIC_AUTO_MERGE_SIMILARITY_THRESHOLD=0.92
MERGE_SEMANTIC_AUTO_MERGE_MIN_EVIDENCE=2

# Monitoring / maintenance
MONITORING_ENABLED=true
MONITORING_POLL_INTERVAL_SECONDS=60
MAINTENANCE_ENABLED=true
MAINTENANCE_POLL_INTERVAL_MINUTES=60
MAINTENANCE_EXTRACTION_ERRORS_RETENTION_DAYS=14
MAINTENANCE_STAGE5_METRICS_RETENTION_DAYS=30
MAINTENANCE_MERGE_DECISIONS_RETENTION_DAYS=90

# Neo4j sync
NEO4J_ENABLED=false
NEO4J_BASE_URL=http://127.0.0.1:7474
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_POLL_INTERVAL_SECONDS=30
NEO4J_BATCH_SIZE=200

# Embedding pipeline
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_POLL_INTERVAL_SECONDS=30
EMBEDDING_BATCH_SIZE=100
